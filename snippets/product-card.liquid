{% comment %}
  FRAGRY — Reusable Product Card
  Usage: {% render 'product-card', product: product %}
{% endcomment %}

{%- liquid
  assign variant_id = product.variants.first.id
  assign has_second = false
  if product.images[1]
    assign has_second = true
  endif
  
  assign notes = ''
  for tag in product.tags
    if tag contains 'note:'
      assign notes = tag | remove: 'note:'
    endif
  endfor
-%}

<li
  class="km-col-card km-fade-up"
  data-variant-id="{{ variant_id }}"
  {% if index %}style="animation-delay: {{ index | modulo: 4 | times: 80 }}ms"{% endif %}
  role="listitem"
>
  <!-- Image -->
  <a href="{{ product.url }}" class="km-col-card__img-wrap" aria-label="Voir {{ product.title | escape }}" tabindex="0">

    {% if product.featured_image %}
      <img
        class="km-col-card__img km-col-card__img--primary"
        src="{{ product.featured_image | image_url: width: 600 }}"
        srcset="{{ product.featured_image | image_url: width: 400 }} 400w, {{ product.featured_image | image_url: width: 600 }} 600w, {{ product.featured_image | image_url: width: 900 }} 900w"
        sizes="(max-width: 480px) 100vw, (max-width: 768px) 50vw, 25vw"
        alt="{{ product.featured_image.alt | default: product.title | escape }}"
        loading="lazy"
        width="600"
        height="800"
      >
      {% if has_second %}
        <img
          class="km-col-card__img km-col-card__img--secondary"
          src="{{ product.images[1] | image_url: width: 600 }}"
          srcset="{{ product.images[1] | image_url: width: 400 }} 400w, {{ product.images[1] | image_url: width: 600 }} 600w"
          sizes="(max-width: 480px) 100vw, (max-width: 768px) 50vw, 25vw"
          alt="{{ product.images[1].alt | default: product.title | escape }}"
          loading="lazy"
          width="600"
          height="800"
          aria-hidden="true"
        >
      {% endif %}
    {% else %}
      <!-- Placeholder image manquante -->
      <div class="km-col-card__placeholder" aria-label="Photo non disponible">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
          <circle cx="8.5" cy="8.5" r="1.5"/>
          <polyline points="21 15 16 10 5 21"/>
        </svg>
        <span>Photo bientôt disponible</span>
      </div>
    {% endif %}

    <!-- Badge -->
    {% if product.compare_at_price > product.price %}
      <span class="km-col-card__badge">Promo</span>
    {% elsif product.tags contains 'nouveau' or product.tags contains 'new' %}
      <span class="km-col-card__badge km-col-card__badge--new">Nouveau</span>
    {% endif %}

    <!-- Notes olfactives overlay -->
    {% if notes != '' %}
      <div class="km-col-card__notes">
        <p class="km-col-card__notes-label">Notes</p>
        <p class="km-col-card__notes-val">{{ notes }}</p>
      </div>
    {% endif %}
  </a>

  <!-- Body -->
  <div class="km-col-card__body">
    {% if product.vendor != blank %}
      <p class="km-col-card__vendor">{{ product.vendor }}</p>
    {% endif %}

    <a href="{{ product.url }}" class="km-col-card__title">{{ product.title }}</a>

    <div class="km-col-card__footer">
      <p class="km-col-card__price">
        {% if product.compare_at_price > product.price %}
          <s class="km-col-card__price-compare">{{ product.compare_at_price | money }}</s>
        {% endif %}
        {{ product.price | money }}
      </p>
      <button
        type="button"
        class="km-col-card__atc"
        data-add-to-cart
        aria-label="Ajouter {{ product.title | escape }} au panier"
      >
        <span class="km-col-card__atc-icon" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
            <line x1="3" y1="6" x2="21" y2="6"/>
            <path d="M16 10a4 4 0 0 1-8 0"/>
          </svg>
        </span>
        <span class="km-col-card__atc-label">Ajouter</span>
      </button>
    </div>
  </div>
</li>
