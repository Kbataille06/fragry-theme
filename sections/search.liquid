{% comment %} FRAGRY — Search Page Premium {% endcomment %}

<div class="km-collection-page km-search-page">
  <!-- ── Hero Banner ── -->
  <section class="km-col-hero">
    <div class="km-col-hero__bg"></div>
    <div class="km-col-hero__content">
      <span class="km-col-hero__eyebrow">Recherche</span>
      {% if search.performed %}
        <h1 class="km-col-hero__title">Résultats pour <em>"{{ search.terms | escape }}"</em></h1>
        <p class="km-col-hero__sub">{{ search.results_count }} résultat{% if search.results_count != 1 %}s{% endif %} trouvé{% if search.results_count != 1 %}s{% endif %}</p>
      {% else %}
        <h1 class="km-col-hero__title">Rechercher sur <em>Fragry</em></h1>
      {% endif %}
      
      <div class="km-col-hero__divider" style="margin-top: 1.5rem; margin-bottom: 2.5rem;">
        <span class="km-col-hero__line"></span>
        <span class="km-col-hero__diamond"></span>
        <span class="km-col-hero__line km-col-hero__line--r"></span>
      </div>

      <form action="{{ routes.search_url }}" method="get" role="search" class="km-search-form">
        <input type="hidden" name="type" value="product">
        <input
          type="search"
          name="q"
          value="{{ search.terms | escape }}"
          placeholder="Un parfum, une marque..."
          class="km-search-input"
        >
        <button type="submit" class="km-btn km-search-btn">Rechercher</button>
      </form>

    </div>
  </section>

  <!-- ── Main Content (Ivory) ── -->
  <div class="km-band km-band--light">
    
    {% if search.performed %}
      <div class="km-col-toolbar">
        <p class="km-col-toolbar__count">
          <span class="km-col-toolbar__count-num">{{ search.results_count }}</span> résultat{% if search.results_count != 1 %}s{% endif %}
        </p>
      </div>

      <!-- ── Products Grid ── -->
      <div class="km-col-section">
        {% paginate search.results by 24 %}

        {% if search.results_count == 0 %}
          <div class="km-col-empty">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/>
            </svg>
            <p>Aucun résultat trouvé pour "{{ search.terms | escape }}".</p>
            <a href="/collections/all" class="km-btn">Explorer notre catalogue</a>
          </div>
        {% else %}
          <ul class="km-col-grid" role="list">
            {% for item in search.results %}
              {% if item.object_type == 'product' %}
                {% render 'product-card', product: item, index: forloop.index0 %}
              {% endif %}
            {% endfor %}
          </ul>

          <!-- Pagination -->
          {% if paginate.pages > 1 %}
            <nav class="km-col-pagination" aria-label="Pagination">
              {% if paginate.previous %}
                <a href="{{ paginate.previous.url }}" class="km-col-pagination__btn" aria-label="Page précédente">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M15 18l-6-6 6-6"/></svg>
                </a>
              {% endif %}

              {% for part in paginate.parts %}
                {% if part.is_link %}
                  <a href="{{ part.url }}" class="km-col-pagination__num">{{ part.title }}</a>
                {% elsif part.title == paginate.current_page %}
                  <span class="km-col-pagination__num km-col-pagination__num--active" aria-current="page">{{ part.title }}</span>
                {% else %}
                  <span class="km-col-pagination__ellipsis">…</span>
                {% endif %}
              {% endfor %}

              {% if paginate.next %}
                <a href="{{ paginate.next.url }}" class="km-col-pagination__btn" aria-label="Page suivante">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M9 18l6-6-6-6"/></svg>
                </a>
              {% endif %}
            </nav>
          {% endif %}

        {% endif %}
        {% endpaginate %}
      </div>
    {% else %}
      <div class="km-col-section" style="min-height: 40vh; display: flex; align-items: center; justify-content: center;">
         <div class="km-col-empty">
           <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="margin: 0 auto 1.5rem;">
              <circle cx="11" cy="11" r="8"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
            <p style="font-size: 1.1rem; color: #555;">Utilisez la barre de recherche ci-dessus pour trouver un parfum.</p>
         </div>
      </div>
    {% endif %}
    
  </div><!-- /km-band--light -->
</div>

<style>
  .km-search-form {
    max-width: 550px;
    margin: 0 auto;
    display: flex;
    gap: 12px;
  }
  .km-search-input {
    flex: 1;
    padding: 14px 24px;
    border-radius: 30px;
    border: 1px solid rgba(255,255,255,0.3);
    background: rgba(255,255,255,0.05);
    color: #fff;
    outline: none;
    font-family: var(--font-body);
    font-size: 1.05rem;
    transition: all 0.3s ease;
  }
  .km-search-input:focus {
    border-color: var(--c-accent-gold);
    background: rgba(255,255,255,0.1);
  }
  .km-search-input::placeholder {
    color: rgba(255,255,255,0.5);
  }
  .km-search-form .km-search-btn {
    border-radius: 30px;
    padding: 12px 32px;
    white-space: nowrap;
    border: none;
    background: var(--c-accent-gold);
    color: #fff;
    font-family: var(--font-heading);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.9rem;
    cursor: pointer;
    transition: background 0.3s;
  }
  .km-search-form .km-search-btn:hover {
    background: #fff;
    color: #000;
  }

  @media (max-width: 600px) {
    .km-search-form {
      flex-direction: column;
      gap: 16px;
    }
    .km-search-form .km-search-btn {
      width: 100%;
    }
  }
</style>

<script>
(function () {
  // ── Fade-up on scroll ──
  var observer = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
      if (e.isIntersecting) {
        e.target.classList.add('km-fade-up--visible');
        observer.unobserve(e.target);
      }
    });
  }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

  document.querySelectorAll('.km-fade-up').forEach(function (el) {
    observer.observe(el);
  });

  // ── Add to cart ──
  document.querySelectorAll('[data-add-to-cart]').forEach(function (btn) {
    btn.addEventListener('click', function (e) {
      e.preventDefault();
      var card = btn.closest('[data-variant-id]');
      if (!card || btn.disabled) return;
      var variantId = Number(card.dataset.variantId);
      if (typeof window.fragryAddToCart === 'function') {
        window.fragryAddToCart(variantId, btn);
      }
    });
  });
})();
</script>

{% schema %}
{
  "name": "Recherche",
  "settings": []
}
{% endschema %}
