{% comment %} FRAGRY — Collection Page Premium {% endcomment %}

{%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
{%- assign current_tags = current_tags | default: blank -%}

<div class="km-collection-page">

<!-- ── Hero Banner ── -->
<section class="km-col-hero">
  <div class="km-col-hero__bg"></div>
  <div class="km-col-hero__content">
    <span class="km-col-hero__eyebrow">{{ collection.title }}</span>
    <h1 class="km-col-hero__title">Notre<em> Catalogue</em></h1>
    <p class="km-col-hero__sub">{{ collection.products_count }} fragrance{% if collection.products_count != 1 %}s{% endif %} d'exception</p>
    <div class="km-col-hero__divider">
      <span class="km-col-hero__line"></span>
      <span class="km-col-hero__diamond"></span>
      <span class="km-col-hero__line km-col-hero__line--r"></span>
    </div>
  </div>
</section>

<!-- ── Main Content (Ivory) ── -->
<div class="km-band km-band--light">
  
  <!-- ── Toolbar (tri + count) ── -->
<div class="km-col-toolbar">
  <p class="km-col-toolbar__count">
    <span class="km-col-toolbar__count-num">{{ collection.products_count }}</span> produits
  </p>
  <form class="km-col-toolbar__sort" id="km-sort-form">
    <label for="km-sort-select" class="km-col-toolbar__sort-label">Trier par</label>
    <div class="km-col-toolbar__select-wrap">
      <select
        id="km-sort-select"
        name="sort_by"
        class="km-col-toolbar__select"
        onchange="this.form.submit()"
        aria-label="Trier les produits"
      >
        <option value="manual" {% if sort_by == 'manual' %}selected{% endif %}>Recommandés</option>
        <option value="best-selling" {% if sort_by == 'best-selling' %}selected{% endif %}>Meilleures ventes</option>
        <option value="title-ascending" {% if sort_by == 'title-ascending' %}selected{% endif %}>A → Z</option>
        <option value="title-descending" {% if sort_by == 'title-descending' %}selected{% endif %}>Z → A</option>
        <option value="price-ascending" {% if sort_by == 'price-ascending' %}selected{% endif %}>Prix croissant</option>
        <option value="price-descending" {% if sort_by == 'price-descending' %}selected{% endif %}>Prix décroissant</option>
      </select>
      <svg class="km-col-toolbar__chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 9l6 6 6-6"/></svg>
    </div>
  </form>
</div>

<!-- ── Products Grid ── -->
<div class="km-col-section">
  {% paginate collection.products by 24 %}

  {% if collection.products_count == 0 %}
    <div class="km-col-empty">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/>
      </svg>
      <p>Aucun produit dans cette collection</p>
      <a href="/collections/all" class="km-btn">Voir tout le catalogue</a>
    </div>
  {% else %}
    <ul class="km-col-grid" role="list">
      {% for product in collection.products %}
        {% render 'product-card', product: product, index: forloop.index0 %}
      {% endfor %}
    </ul>

    <!-- Pagination -->
    {% if paginate.pages > 1 %}
      <nav class="km-col-pagination" aria-label="Pagination">
        {% if paginate.previous %}
          <a href="{{ paginate.previous.url }}" class="km-col-pagination__btn" aria-label="Page précédente">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M15 18l-6-6 6-6"/></svg>
          </a>
        {% endif %}

        {% for part in paginate.parts %}
          {% if part.is_link %}
            <a href="{{ part.url }}" class="km-col-pagination__num">{{ part.title }}</a>
          {% elsif part.title == paginate.current_page %}
            <span class="km-col-pagination__num km-col-pagination__num--active" aria-current="page">{{ part.title }}</span>
          {% else %}
            <span class="km-col-pagination__ellipsis">…</span>
          {% endif %}
        {% endfor %}

        {% if paginate.next %}
          <a href="{{ paginate.next.url }}" class="km-col-pagination__btn" aria-label="Page suivante">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M9 18l6-6-6-6"/></svg>
          </a>
        {% endif %}
      </nav>
    {% endif %}

  {% endif %}
  {% endpaginate %}
</div>

  </div><!-- /km-band--light -->
</div>{{- '<!-- /km-collection-page -->' -}}

<script>
(function () {
  // ── Fade-up on scroll ──
  var observer = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
      if (e.isIntersecting) {
        e.target.classList.add('km-fade-up--visible');
        observer.unobserve(e.target);
      }
    });
  }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

  document.querySelectorAll('.km-fade-up').forEach(function (el) {
    observer.observe(el);
  });

  // ── Add to cart ──
  document.querySelectorAll('[data-add-to-cart]').forEach(function (btn) {
    btn.addEventListener('click', function (e) {
      e.preventDefault();
      var card = btn.closest('[data-variant-id]');
      if (!card || btn.disabled) return;
      var variantId = Number(card.dataset.variantId);
      if (typeof window.fragryAddToCart === 'function') {
        window.fragryAddToCart(variantId, btn);
      }
    });
  });
})();
</script>

{% schema %}
{
  "name": "Collection Fragry",
  "settings": []
}
{% endschema %}
