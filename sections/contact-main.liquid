{%- style -%}
  .contact-section {
    padding: var(--space-xl) 0;
    background-color: var(--c-bg-dark);
    color: var(--c-text-light);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }

  @media (min-width: 992px) {
    .contact-grid {
      grid-template-columns: 1.5fr 1fr;
    }
  }

  .contact-header {
    text-align: center;
    margin-bottom: var(--space-lg);
  }

  .contact-header h1 {
    font-size: clamp(2.5rem, 5vw, 4rem);
    margin-bottom: var(--space-sm);
  }

  .contact-header p {
    color: var(--c-text-muted);
    max-width: 600px;
    margin: 0 auto;
  }

  .contact-form-wrapper {
    background: rgba(255, 255, 255, 0.03);
    padding: var(--space-md);
    border: 1px solid var(--c-border);
    border-radius: 4px;
    backdrop-filter: blur(10px);
  }

  .contact-form .field {
    margin-bottom: var(--space-md);
  }

  .contact-form label {
    display: block;
    margin-bottom: var(--space-xs);
    font-family: var(--font-body);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--c-accent-gold);
  }

  .contact-form input,
  .contact-form textarea,
  .contact-form select {
    width: 100%;
    padding: 1rem;
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid var(--c-border);
    color: var(--c-text-light);
    font-family: var(--font-body);
    font-size: 1rem;
    transition: all 0.3s var(--ease-out-expo);
    border-radius: 2px;
  }

  .contact-form input:focus,
  .contact-form textarea:focus {
    outline: none;
    border-color: var(--c-accent-gold);
    background: rgba(0, 0, 0, 0.5);
    box-shadow: 0 0 15px rgba(212, 175, 55, 0.1);
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .info-item {
    padding: var(--space-md);
    border: 1px solid var(--c-border);
    border-radius: 4px;
    transition: all 0.3s var(--ease-out-expo);
  }

  .info-item:hover {
    border-color: var(--c-accent-gold);
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
  }

  .info-item h3 {
    font-size: 1.2rem;
    color: var(--c-accent-gold);
    margin-bottom: var(--space-xs);
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .info-item p, .info-item a {
    color: var(--c-text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .info-item a:hover {
    color: var(--c-text-light);
  }

  .opening-hours {
    list-style: none;
    margin-top: var(--space-sm);
  }

  .opening-hours li {
    display: flex;
    justify-content: space-between;
    padding: 8px 0;
    border-bottom: 1px solid var(--c-border);
    font-size: 0.9rem;
  }

  .opening-hours li:last-child {
    border-bottom: none;
  }

  .opening-hours .day {
    color: var(--c-text-light);
  }

  .opening-hours .hours {
    color: var(--c-text-muted);
  }
{%- endstyle -%}

<section class="contact-section">
  <div class="container">
    <header class="contact-header">
      <h1 class="hero__title">{{ section.settings.title }}</h1>
      <p class="hero__text">{{ section.settings.subtitle }}</p>
    </header>

    <div class="contact-grid">
      <div class="contact-form-wrapper">
        {%- form 'contact', id: 'ContactForm', class: 'contact-form' -%}
          {%- if form.posted_successfully? -%}
            <div class="contact-success" role="status">
              {{ 'templates.contact.form.post_success' | t | default: "Votre message a été envoyé avec succès. Nous vous répondrons dans les plus brefs délais." }}
            </div>
          {%- elsif form.errors -%}
            <div class="contact-error">
              {{ form.errors | default_errors }}
            </div>
          {%- endif -%}

          <div class="contact-grid" style="grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: var(--space-md); margin-bottom: 0;">
            <div class="field">
              <label for="ContactForm-name">Nom complet</label>
              <input
                type="text"
                id="ContactForm-name"
                name="contact[name]"
                value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
                placeholder="Ex: Jean Dupont"
                required
              >
            </div>
            <div class="field">
              <label for="ContactForm-email">Adresse E-mail</label>
              <input
                type="email"
                id="ContactForm-email"
                name="contact[email]"
                autocorrect="off"
                autocapitalize="off"
                value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
                aria-required="true"
                placeholder="email@exemple.com"
                required
              >
            </div>
          </div>

          <div class="field">
            <label for="ContactForm-phone">Numéro de téléphone (optionnel)</label>
            <input
              type="tel"
              id="ContactForm-phone"
              name="contact[phone]"
              pattern="[0-9\-]*"
              value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}"
              placeholder="+33 6 00 00 00 00"
            >
          </div>

          <div class="field">
            <label for="ContactForm-subject">Sujet de votre demande</label>
            <select id="ContactForm-subject" name="contact[subject]">
              <option value="Conseil personnalisé">Conseil personnalisé</option>
              <option value="Suivi de commande">Suivi de commande</option>
              <option value="Partenariat">Partenariat</option>
              <option value="Autre">Autre</option>
            </select>
          </div>

          <div class="field">
            <label for="ContactForm-body">Votre Message</label>
            <textarea
              rows="6"
              id="ContactForm-body"
              name="contact[body]"
              placeholder="Comment pouvons-nous vous aider ?"
              required
            >
              {{- form.body -}}
            </textarea>
          </div>

          <div class="contact__button">
            <button type="submit" class="btn btn--outline" style="width: 100%;">
              Envoyer le message
              <span class="btn__icon">→</span>
            </button>
          </div>
        {%- endform -%}
      </div>

      <div class="contact-info">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'address' -%}
              <div class="info-item" {{ block.shopify_attributes }}>
                <h3>
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                  {{ block.settings.heading }}
                </h3>
                <p>
                  {{ block.settings.address | nl2br }}
                </p>
              </div>

            {%- when 'contact_details' -%}
              <div class="info-item" {{ block.shopify_attributes }}>
                <h3>
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l2.28-2.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                  {{ block.settings.heading }}
                </h3>
                <p>
                  Tél: <a href="tel:{{ block.settings.phone | replace: ' ', '' }}">{{ block.settings.phone }}</a><br>
                  Email: <a href="mailto:{{ block.settings.email }}">{{ block.settings.email }}</a>
                </p>
              </div>

            {%- when 'hours' -%}
              <div class="info-item" {{ block.shopify_attributes }}>
                <h3>
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  {{ block.settings.heading }}
                </h3>
                <ul class="opening-hours">
                  {%- if block.settings.mon_fri != blank -%}
                    <li><span class="day">Lundi - Vendredi</span> <span class="hours">{{ block.settings.mon_fri }}</span></li>
                  {%- endif -%}
                  {%- if block.settings.sat != blank -%}
                    <li><span class="day">Samedi</span> <span class="hours">{{ block.settings.sat }}</span></li>
                  {%- endif -%}
                  {%- if block.settings.sun != blank -%}
                    <li><span class="day">Dimanche</span> <span class="hours">{{ block.settings.sun }}</span></li>
                  {%- endif -%}
                </ul>
              </div>
          {%- endcase -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Page Contact Fragry",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titre",
      "default": "Contactez-nous"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Sous-titre",
      "default": "Une question ? Une demande particulière ? Nos conseillers sont à votre entière disposition."
    }
  ],
  "blocks": [
    {
      "type": "address",
      "name": "Adresse Showroom",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Titre",
          "default": "Notre Showroom"
        },
        {
          "type": "textarea",
          "id": "address",
          "label": "Adresse",
          "default": "15 Place Vendôme\n75001 Paris, France"
        }
      ]
    },
    {
      "type": "contact_details",
      "name": "Coordonnées",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Titre",
          "default": "Contact Direct"
        },
        {
          "type": "text",
          "id": "phone",
          "label": "Téléphone",
          "default": "+33 1 23 45 67 89"
        },
        {
          "type": "text",
          "id": "email",
          "label": "E-mail",
          "default": "contact@fragry.com"
        }
      ]
    },
    {
      "type": "hours",
      "name": "Horaires",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Titre",
          "default": "Horaires d'ouverture"
        },
        {
          "type": "text",
          "id": "mon_fri",
          "label": "Lundi - Vendredi",
          "default": "10:00 - 19:00"
        },
        {
          "type": "text",
          "id": "sat",
          "label": "Samedi",
          "default": "11:00 - 18:00"
        },
        {
          "type": "text",
          "id": "sun",
          "label": "Dimanche",
          "default": "Fermé"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Page Contact Fragry",
      "blocks": [
        { "type": "address" },
        { "type": "contact_details" },
        { "type": "hours" }
      ]
    }
  ]
}
{% endschema %}
