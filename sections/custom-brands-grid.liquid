{%- style -%}
  #km-brands-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  
  .km-brand-card {
    background: transparent !important;
    overflow: visible !important;
  }
  
  .km-brand-card__image-wrap {
    width: 100%;
    aspect-ratio: 1/1;
    background: var(--c-surface);
    border-radius: 4px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 10%;
    transition: transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1), box-shadow 0.4s ease;
  }
  
  .km-brand-card:hover .km-brand-card__image-wrap {
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.05);
  }
  
  .km-brand-card__image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  
  .km-brand-card:hover .km-brand-card__image {
    transform: scale(1.05);
  }
  
  .km-brand-card__content {
    text-align: center;
    padding-top: 15px;
  }
  
  .km-brand-card__title {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--band-heading, var(--c-heading));
    transition: color 0.3s ease;
  }
  
  .km-brand-card:hover .km-brand-card__title {
    color: var(--c-accent-gold);
  }
{%- endstyle -%}

<div class="km-band km-band--{{ section.settings.color_scheme }}">
  <div class="km-section" id="km-brands-{{ section.id }}">
    
    {%- if section.settings.title != blank or section.settings.eyebrow != blank -%}
      <div class="km-section__header">
        {%- if section.settings.eyebrow != blank -%}
          <span class="km-section__eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        {%- if section.settings.title != blank -%}
          <h2 class="km-section__title">{{ section.settings.title }}</h2>
        {%- endif -%}
        <div class="km-section__divider"></div>
      </div>
    {%- endif -%}

    <div class="km-categories-grid">
      {%- comment -%}
        We iterate through the 'marque' metaobject. 
        Adjust the handle 'marque' if your metaobject uses a different one.
      {%- endcomment -%}
      {%- for brand in shop.metaobjects.marque.values -%}
        {%- liquid
          # Adjust field handles if necessary (e.g., brand.name, brand.logo)
          assign brand_name = brand.nom.value | default: brand.name.value | default: brand.system.handle | capitalize
          assign brand_logo = brand.logo.value | default: brand.image.value
          
          # Construct filter URL. 
          # This assumes you have a product metafield 'custom.maison_de_parfum' enabled as a filter.
          assign filter_param = section.settings.filter_key | default: 'filter.p.m.custom.maison_de_parfum'
          # Dynamic URL for the brand page
          assign brand_url = brand.system.url | default: filter_url
        -%}
        
        <a href="{{ brand_url }}" class="km-category-card km-category-card--33 km-brand-card">
          <div class="km-brand-card__image-wrap">
            {%- if brand_logo != blank -%}
              {{ brand_logo | image_url: width: 800 | image_tag: 
                loading: 'lazy', 
                class: 'km-brand-card__image',
                widths: '400, 600, 800'
              }}
            {%- else -%}
              <div style="color: var(--c-accent-gold); font-family: var(--font-heading); font-size: 3rem; text-transform: uppercase;">
                <span>{{ brand_name | slice: 0 | upcase }}</span>
              </div>
            {%- endif -%}
          </div>
          
          <div class="km-brand-card__content">
            <h3 class="km-brand-card__title">{{ brand_name }}</h3>
          </div>
        </a>
      {%- else -%}
        <p style="grid-column: 1 / -1; text-align: center; opacity: 0.5; padding: 40px;">
          Aucune marque trouvée. Assurez-vous d'avoir créé des entrées dans le métaobjet "Marque".
        </p>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Liste des Marques",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Sourcil",
      "default": "MAISONS DE PARFUM"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titre",
      "default": "Nos Marques"
    },
    {
      "type": "text",
      "id": "filter_key",
      "label": "Clé du filtre URL",
      "info": "Ex: filter.p.m.custom.maison_de_parfum",
      "default": "filter.p.m.custom.maison_de_parfum"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Couleurs de la bande",
      "options": [
        { "value": "light", "label": "Ivoire (Clair)" },
        { "value": "dark", "label": "Noir (Sombre)" }
      ],
      "default": "light"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding haut",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bas",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Liste des Marques"
    }
  ]
}
{% endschema %}
