{%- comment -%}
  Section: product-recommendations.liquid
  Affiche les recommandations basées sur l'intent (related ou complementary).
{%- endcomment -%}

<div class="antigravity-recommendations-section" 
     data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit={{ section.settings.limit }}&intent={{ section.settings.intent }}"
     data-product-recommendations>
  
  {%- if recommendations.performed and recommendations.products_count > 0 -%}
    <div class="antigravity-recommendations">
      <h2 class="antigravity-recommendations__title">{{ section.settings.title | escape }}</h2>
      <div class="antigravity-recommendations__grid">
        {%- for product in recommendations.products -%}
          <a href="{{ product.url }}" class="antigravity-product-card">
            <img class="antigravity-product-card__image" 
                 src="{{ product.featured_media | image_url: width: 400 }}" 
                 alt="{{ product.title | escape }}" 
                 loading="lazy" 
                 width="400" 
                 height="533">
            <h3 class="antigravity-product-card__title">{{ product.title }}</h3>
            <p class="antigravity-product-card__price">{{ product.price | money }}</p>
          </a>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Recommandations Luxe",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titre de la section",
      "default": "Complétez votre sillage"
    },
    {
      "type": "select",
      "id": "intent",
      "label": "Type de recommandation",
      "options": [
        {
          "value": "related",
          "label": "Produits associés (Recommandations)"
        },
        {
          "value": "complementary",
          "label": "Produits complémentaires"
        }
      ],
      "default": "related",
      "info": "Défini dans l'application Search & Discovery"
    },
    {
      "type": "range",
      "id": "limit",
      "label": "Nombre de produits",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Recommandations Luxe"
    }
  ]
}
{% endschema %}
