{% comment %}
  FRAGRY — Header + Mobile Menu
  Alpine.js déclaré dans un <script> isolé pour éviter
  tout conflit de parsing Liquid avec les arrow functions
{% endcomment %}

<style>
  #shopify-section-{{ section.id }} {
    position: sticky;
    top: 0;
    z-index: 50;
  }
</style>
<div id="km-header-root-{{ section.id }}">

  <header class="km-header" id="km-main-header" role="banner">
    {%- comment -%} Left nav {%- endcomment -%}
    <nav aria-label="Navigation principale">
      <ul class="km-header__nav km-header__nav--left">
        {%- for link in linklists[section.settings.menu_left].links -%}
          {%- if link.links != blank -%}
            <li class="km-header__has-dropdown">
              <a href="{{ link.url }}" {% if link.active %}aria-current="page"{% endif %} class="km-header__dropdown-trigger">
                {{ link.title }}
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-left:4px;vertical-align:middle;"><path d="M6 9l6 6 6-6"/></svg>
              </a>
              <ul class="km-header__dropdown">
                {%- for childlink in link.links -%}
                  <li>
                    <a href="{{ childlink.url }}" {% if childlink.active %}aria-current="page"{% endif %}>
                      {{ childlink.title }}
                    </a>
                  </li>
                {%- endfor -%}
              </ul>
            </li>
          {%- else -%}
            <li>
              <a href="{{ link.url }}" {% if link.active %}aria-current="page"{% endif %}>
                {{ link.title }}
              </a>
            </li>
          {%- endif -%}
        {%- else -%}
          <li><a href="/collections">Collections</a></li>
          <li><a href="/collections/all">Catalogue</a></li>
        {%- endfor -%}
      </ul>
    </nav>

    {%- comment -%} Logo {%- endcomment -%}
    <div class="km-header__logo">
      <a href="/" aria-label="{{ shop.name }} - Accueil">
        {%- if section.settings.logo != blank -%}
          <img
            src="{{ section.settings.logo | image_url: width: 400 }}"
            alt="{{ shop.name }}"
            width="250"
            height="auto"
            loading="eager"
          >
        {%- else -%}
          {{ shop.name }}
        {%- endif -%}
      </a>
    </div>

    {%- comment -%} Right actions {%- endcomment -%}
    <div class="km-header__nav km-header__nav--right" style="gap: 4px;">
      <a href="{{ routes.account_url }}" class="km-header__icon-btn" aria-label="Mon compte">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
        </svg>
      </a>

      <button
        type="button"
        id="km-header-cart-btn"
        class="km-header__icon-btn"
        aria-label="Ouvrir le panier"
        aria-haspopup="dialog"
        aria-controls="km-mini-cart"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
        {%- if cart.item_count > 0 -%}
          <span class="km-cart-count" aria-hidden="true">{{ cart.item_count }}</span>
        {%- else -%}
          <span class="km-cart-count" aria-hidden="true" style="display:none">0</span>
        {%- endif -%}
      </button>


      <button
        type="button"
        class="km-header__icon-btn km-header__hamburger"
        id="km-menu-open-btn"
        aria-label="Ouvrir le menu"
        aria-expanded="false"
        aria-controls="km-nav-drawer"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true" focusable="false">
          <path d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </header>

  {%- comment -%} Overlay {%- endcomment -%}
  <div
    class="km-nav-overlay"
    id="km-nav-overlay"
    style="display: none;"
    aria-hidden="true"
  ></div>

  {%- comment -%} Drawer {%- endcomment -%}
  <aside
    class="km-nav-drawer"
    id="km-nav-drawer"
    style="display: none;"
    role="dialog"
    aria-modal="true"
    aria-label="Menu de navigation"
  >
    <div class="km-nav-drawer__header">
      <span class="km-nav-drawer__logo">{{ shop.name }}</span>
      <button
        type="button"
        class="km-nav-drawer__close"
        id="km-menu-close-btn"
        aria-label="Fermer le menu"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
          <path d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <div class="km-nav-drawer__divider"></div>

    <nav aria-label="Navigation mobile">
      <ul class="km-nav-drawer__links">
        {%- for link in linklists[section.settings.menu_left].links -%}
          {%- if link.links != blank -%}
            <li class="km-nav-drawer__has-dropdown">
              <div class="km-nav-drawer__dropdown-trigger-wrap" style="display: flex; justify-content: space-between; align-items: center;">
                <a href="{{ link.url }}" {% if link.active %}aria-current="page"{% endif %}>
                  {{ link.title }}
                </a>
                <button type="button" class="km-nav-drawer__dropdown-toggle" aria-expanded="false" onclick="this.closest('li').classList.toggle('is-open'); this.setAttribute('aria-expanded', this.closest('li').classList.contains('is-open'))" style="background: none; border: none; color: inherit; padding: 8px;">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="transition: transform 0.3s;"><path d="M6 9l6 6 6-6"/></svg>
                </button>
              </div>
              <ul class="km-nav-drawer__dropdown">
                {%- for childlink in link.links -%}
                  <li>
                    <a href="{{ childlink.url }}" {% if childlink.active %}aria-current="page"{% endif %}>
                      {{ childlink.title }}
                    </a>
                  </li>
                {%- endfor -%}
              </ul>
            </li>
          {%- else -%}
            <li>
              <a href="{{ link.url }}" {% if link.active %}aria-current="page"{% endif %}>
                {{ link.title }}
              </a>
            </li>
          {%- endif -%}
        {%- else -%}
          <li><a href="/collections">Collections</a></li>
          <li><a href="/collections/all">Catalogue</a></li>
          <li><a href="/pages/notre-histoire">Notre Histoire</a></li>
          <li><a href="/pages/contact">Contact</a></li>
        {%- endfor -%}
      </ul>
    </nav>

    <div class="km-nav-drawer__footer">
      <a href="{{ routes.account_url }}">Mon Compte</a>
      <button
        type="button"
        id="km-drawer-cart-btn"
        class="km-mini-cart__open-btn"
        style="background:none;border:none;color:inherit;font:inherit;cursor:pointer;text-align:left;padding:0;letter-spacing:0.2em;font-size:0.7rem;text-transform:uppercase;"
        aria-label="Ouvrir le panier"
      >Panier ({{ cart.item_count }})</button>
    </div>
  </aside>


</div>

{%- comment -%}
  Vanilla JS pour le header — aucun Alpine, aucun conflit Liquid.
  Le sticky glassmorphism est géré par scroll event + classList.
{%- endcomment -%}
<script>
(function() {
  var header  = document.getElementById('km-main-header');
  var overlay = document.getElementById('km-nav-overlay');
  var drawer  = document.getElementById('km-nav-drawer');
  var btnOpen = document.getElementById('km-menu-open-btn');
  var btnClose = document.getElementById('km-menu-close-btn');

  if (!header) return;

  // Sticky glassmorphism
  window.addEventListener('scroll', function() {
    if (window.scrollY > 60) {
      header.classList.add('km-header--scrolled');
    } else {
      header.classList.remove('km-header--scrolled');
    }
  }, { passive: true });

  // Mobile menu open
  if (btnOpen && drawer && overlay) {
    btnOpen.addEventListener('click', function() {
      drawer.style.display  = 'flex';
      overlay.style.display = 'block';
      btnOpen.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    });

    // Mobile menu close
    function closeMenu() {
      drawer.style.display  = 'none';
      overlay.style.display = 'none';
      btnOpen.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }

    btnClose.addEventListener('click', closeMenu);
    overlay.addEventListener('click', closeMenu);
  }
})();
</script>

{% schema %}
{
  "name": "Header Fragry",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "link_list",
      "id": "menu_left",
      "label": "Menu principal",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
