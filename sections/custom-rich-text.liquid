<div class="km-band km-band--light">
<section class="km-section km-rich-text" id="km-rich-text-{{ section.id }}">
  <div class="km-rich-text__inner">

    {%- liquid
      if section.settings.layout == 'image_right'
        assign order_image = 2
        assign order_text  = 1
      else
        assign order_image = 1
        assign order_text  = 2
      endif
    -%}

    <div class="km-rich-text__image-wrap" style="order: {{ order_image }};">
      {%- if section.settings.image != blank -%}
        <img
          class="km-rich-text__image"
          src="{{ section.settings.image | image_url: width: 800 }}"
          srcset="
            {{ section.settings.image | image_url: width: 600 }} 600w,
            {{ section.settings.image | image_url: width: 900 }} 900w,
            {{ section.settings.image | image_url: width: 1200 }} 1200w
          "
          sizes="(max-width: 768px) 100vw, 50vw"
          alt="{{ section.settings.image.alt | default: section.settings.heading | escape }}"
          loading="lazy"
          width="800"
          height="1000"
        >
      {%- else -%}
        {{ 'image' | placeholder_svg_tag: 'km-rich-text__image' }}
      {%- endif -%}
    </div>

    <div class="km-rich-text__content" style="order: {{ order_text }};">
      {%- if section.settings.eyebrow != blank -%}
        <span class="km-rich-text__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="km-rich-text__title">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.body != blank -%}
        <div class="km-rich-text__body">{{ section.settings.body }}</div>
      {%- endif -%}

      {%- if section.settings.cta_label != blank and section.settings.cta_url != blank -%}
        <a href="{{ section.settings.cta_url }}" class="km-btn km-btn--ghost">
          {{ section.settings.cta_label }}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
      {%- endif -%}
    </div>

  </div>
</section>
</div>{{- '<!-- /km-band rich-text -->' -}}

{% schema %}
{
  "name": "Histoire / Texte Riche",
  "tag": "section",
  "settings": [
    {
      "type": "select",
      "id": "layout",
      "label": "Position de l'image",
      "options": [
        { "value": "image_left", "label": "Image à gauche" },
        { "value": "image_right", "label": "Image à droite" }
      ],
      "default": "image_left"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Surtitre",
      "default": "Notre Maison"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "L'Art de Parfumer depuis 2010"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Contenu",
      "default": "<p>K&M Parfumerie est née d'une passion pour les fragrances d'exception. Chaque flacon est sélectionné avec soin pour offrir une expérience olfactive unique et mémorable.</p>"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Texte du bouton",
      "default": "Notre histoire"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Lien du bouton",
      "default": "/pages/notre-histoire"
    }
  ],
  "presets": [
    {
      "name": "Histoire / Texte Riche"
    }
  ]
}
{% endschema %}
