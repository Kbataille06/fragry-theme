<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="theme-color" content="#0a0a0f">

    {% render 'meta-tags' %}

    {%- comment -%} Shopify font face declarations {%- endcomment -%}
    {% render 'css-variables' %}

    {%- comment -%} Google Fonts — Noto Serif + Manrope {%- endcomment -%}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600&family=Noto+Serif:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">

    {%- comment -%} Theme design system {%- endcomment -%}
    {{ 'fragry.css' | asset_url | stylesheet_tag }}

    {{ content_for_header }}
  </head>
  <body>

    {% sections 'header-group' %}

    <main id="main-content" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {%- comment -%} Mini Cart Drawer — global, partagé entre toutes les sections {%- endcomment -%}
    {% render 'mini-cart' %}

    {% sections 'footer-group' %}

    {%- comment -%} Global vanilla JS {%- endcomment -%}
    <script src="{{ 'fragry.js' | asset_url }}" defer></script>

    {%- comment -%} Mini-cart global JS {%- endcomment -%}
    <script src="{{ 'mini-cart.js' | asset_url }}" defer></script>

  </body>
</html>
